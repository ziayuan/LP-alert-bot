# V3 LP Position Monitor Configuration

# ==========================================
# 1. Telegram Bot Settings
# ==========================================
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"
ALLOWED_USER_IDS="YOUR_TELEGRAM_USER_ID_HERE"

# ==========================================
# 2. Monitor Settings
# ==========================================
CHECK_INTERVAL_SECONDS=60
WARNING_THRESHOLD_PERCENT=0.05

# ==========================================
# 3. Positions (JSON Array)
# ==========================================
# Each position specifies its own chain, RPC, and contract addresses.
# use_poa_middleware: true for BSC, false for most other chains.
#
# Example with BSC (PancakeSwap V3) + HyperEVM (Project X):
POSITIONS='[
  {
    "chain": "BSC",
    "rpc_url": "https://bsc-dataseed1.defibit.io/",
    "position_manager": "0x46A15B0b27311cedF172AB29E4f4766fbE7F4364",
    "factory": "0x0BFbCF9fa4f9C56B0F40a671Ad40E0805A091865",
    "position_id": 12345,
    "initial_tx_hash": "0xYourBscTxHash",
    "use_poa_middleware": true
  },
  {
    "chain": "HyperEVM",
    "rpc_url": "https://rpc.hyperliquid.xyz/evm",
    "position_manager": "0xeaD19AE861c29bBb2101E834922B2FEee69B9091",
    "factory": "0xFf7B3e8C00e57ea31477c32A5B52a58Eea47b072",
    "position_id": 67890,
    "initial_tx_hash": "0xYourHyperEvmTxHash",
    "use_poa_middleware": false
  }
]'
